# Application Server Configuration
PORT=8000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database Connection (PostgreSQL 16)
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/agentic_career_db?schema=public"

# Redis Cache Connection
REDIS_URL="redis://localhost:6379"

# JWT Authentication
JWT_SECRET=super_secret_jwt_access_key_change_in_production_32bytes
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super_secret_jwt_refresh_key_change_in_production_32bytes
JWT_REFRESH_EXPIRES_IN=7d

# Google AI Gemini Credentials
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Provider APIs (Optional / Free Tier)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
JOOBLE_API_KEY=your_jooble_api_key

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Twilio WhatsApp Notifications
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# SMTP Email Sender
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password
EMAIL_FROM="Agentic AI Career Platform <noreply@agentic-career.com>"
