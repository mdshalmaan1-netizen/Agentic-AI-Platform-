# Google Gemini API Key
# Get one for free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (flash = fast & cheap, pro = higher quality)
GEMINI_MODEL=gemini-1.5-flash

# Server port
PORT=5000

# Environment
NODE_ENV=development

# ---------------------------------------------------------------
# WhatsApp Notifications (via Twilio WhatsApp API)
# Get free sandbox credentials at: https://www.twilio.com/try-twilio
# Sandbox setup guide: https://www.twilio.com/docs/whatsapp/sandbox
# ---------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# The Twilio Sandbox WhatsApp number (default sandbox number shown below)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
